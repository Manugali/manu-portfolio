{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@locallaunch/ui": ["packages/ui/src/index.ts"],
      "@locallaunch/types": ["packages/types/src/index.ts"],
      "@locallaunch/prompts": ["packages/prompts/src/index.ts"],
      "@locallaunch/templates": ["packages/templates/src/index.ts"],
      "@locallaunch/business-logic": ["packages/business-logic/src/index.ts"]
    }
  }
}
